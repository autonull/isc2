{
  "name": "isc-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Internet Semantic Chat - Decentralized P2P social platform",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "dev:browser": "turbo run dev --filter=@isc/apps/browser",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "cleanup": "bash scripts/cleanup.sh"
  },
  "devDependencies": {
    "@libp2p/interface": "^3.1.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/eslint-plugin-tslint": "^7.0.2",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "turbo": "^1.11.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.12.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/bootstrap": "^12.0.13",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/kad-dht": "^16.1.5",
    "@libp2p/peer-id": "^6.0.4",
    "@libp2p/websockets": "^10.1.5",
    "@libp2p/webtransport": "^6.0.14",
    "@multiformats/multiaddr": "^13.0.1",
    "libp2p": "^3.1.5",
    "preact": "10.19.3"
  }
}
