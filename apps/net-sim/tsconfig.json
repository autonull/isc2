{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": false,
    "baseUrl": ".",
    "paths": {
      "@isc/core": ["../../packages/core/dist/index.js"],
      "@isc/core/*": ["../../packages/core/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/test*.ts", "node_modules", "dist"]
}
