{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@isc/core": ["../../packages/core/src/index.ts"],
      "@isc/core/*": ["../../packages/core/src/*"],
      "@isc/adapters": ["../../packages/adapters/src/index.ts"],
      "@isc/adapters/*": ["../../packages/adapters/src/*"],
      "@isc/protocol": ["../../packages/protocol/src/index.ts"],
      "@isc/protocol/*": ["../../packages/protocol/src/*"],
      "@isc/state": ["../../packages/state/src/index.ts"],
      "@isc/state/*": ["../../packages/state/src/*"],
      "@isc/ui": ["../../packages/ui/src/index.ts"],
      "@isc/ui/*": ["../../packages/ui/src/*"],
      "@isc/navigation": ["../../packages/navigation/src/index.ts"],
      "@isc/navigation/*": ["../../packages/navigation/src/*"],
      "@isc/notifications": ["../../packages/notifications/src/index.ts"],
      "@isc/notifications/*": ["../../packages/notifications/src/*"],
      "@isc/forms": ["../../packages/forms/src/index.ts"],
      "@isc/forms/*": ["../../packages/forms/src/*"],
      "@isc/a11y": ["../../packages/a11y/src/index.ts"],
      "@isc/a11y/*": ["../../packages/a11y/src/*"],
      "@isc/social": ["../../packages/social/src/index.ts"],
      "@isc/social/*": ["../../packages/social/src/*"],
      "@isc/network": ["../../packages/network/src/index.ts"],
      "@isc/network/*": ["../../packages/network/src/*"],
      "@isc/delegation": ["../../packages/delegation/src/index.ts"],
      "@isc/delegation/*": ["../../packages/delegation/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/shared-workers/**/*.ts"
  ]
}
