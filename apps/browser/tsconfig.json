{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/social/audioSpaces.ts",
    "src/social/communities.ts",
    "src/social/directMessages.ts",
    "src/social/moderation.ts",
    "src/social/trending.ts",
    "src/social/semanticMap.ts",
    "src/social/thoughtBridge.ts"
  ]
}
