{
  "name": "@isc/apps/node",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^10.1.1",
    "@chainsafe/libp2p-noise": "^14.1.0",
    "@chainsafe/libp2p-yamux": "^6.0.2",
    "@isc/adapters": "workspace:*",
    "@isc/core": "workspace:*",
    "@isc/protocol": "workspace:*",
    "@libp2p/bootstrap": "^12.0.14",
    "@libp2p/circuit-relay-v2": "^1.1.5",
    "@libp2p/crypto": "^3.0.4",
    "@libp2p/identify": "^2.1.5",
    "@libp2p/kad-dht": "^12.1.5",
    "@libp2p/peer-id": "^4.2.4",
    "@libp2p/peer-id-factory": "^4.2.4",
    "@libp2p/ping": "^1.1.6",
    "@libp2p/websockets": "^8.2.0",
    "@libp2p/webtransport": "^4.1.9",
    "@multiformats/multiaddr": "^13.0.1",
    "libp2p": "^1.9.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
