{
  "name": "@isc/apps/node",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^13.2.0",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@isc/adapters": "workspace:*",
    "@isc/core": "workspace:*",
    "@isc/protocol": "workspace:*",
    "@libp2p/bootstrap": "^12.0.14",
    "@libp2p/kad-dht": "^16.1.6",
    "@libp2p/websockets": "^10.1.6",
    "@libp2p/webtransport": "^6.0.15",
    "@multiformats/multiaddr": "^13.0.1",
    "libp2p": "^3.1.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
