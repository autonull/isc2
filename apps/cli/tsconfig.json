{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": false,
    "allowJs": true
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.d.ts", "tests/**/*.ts"],
  "exclude": ["node_modules"]
}
