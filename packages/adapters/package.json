{
  "name": "@isc/adapters",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser/index.ts",
    "./node": "./src/node/index.ts",
    "./shared": "./src/shared/index.ts",
    "./interfaces": "./src/interfaces/index.ts",
    "./storage": "./src/storage.ts",
    "./identity": "./src/identity.ts"
  },
  "scripts": {
    "build": "echo 'No build - using tsx for dynamic TypeScript execution'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "echo 'Use tsx for runtime - TypeScript module resolution works at runtime'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^13.2.0",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@isc/core": "workspace:*",
    "@libp2p/bootstrap": "^12.0.13",
    "@libp2p/crypto": "^5.1.13",
    "@libp2p/kad-dht": "^16.1.5",
    "@libp2p/peer-id": "^6.0.4",
    "@libp2p/webrtc": "^5.2.5",
    "@libp2p/websockets": "^10.1.5",
    "@libp2p/webtransport": "^6.0.14",
    "@multiformats/multiaddr": "^13.0.1",
    "libp2p": "^3.1.5"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.6",
    "level": "^8.0",
    "onnxruntime-node": "^1.17"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    },
    "level": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "tsx": "^4.7.0"
  },
  "keywords": [
    "isc",
    "adapters",
    "storage",
    "network",
    "model"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
