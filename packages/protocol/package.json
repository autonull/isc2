{
  "name": "@isc/protocol",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./constants": "./dist/constants.js",
    "./keys": "./dist/keys.js",
    "./messages": "./dist/messages.js",
    "./handlers": "./dist/handlers/index.js"
  },
  "scripts": {
