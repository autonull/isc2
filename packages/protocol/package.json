{
  "name": "@isc/protocol",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants.ts",
    "./keys": "./src/keys.ts",
    "./messages": "./src/messages.ts",
    "./handlers": "./src/handlers/index.ts"
  },
  "scripts": {
    "build": "echo 'No build - using tsx'",
