{
  "name": "@isc/social",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": "./src/index.ts",
    "./posts": "./src/posts.ts",
    "./feeds": "./src/feeds.ts",
    "./chat": "./src/chat.ts",
    "./discovery": "./src/discovery.ts",
    "./channels": "./src/channels.ts",
    "./moderation": "./src/moderation/index.ts",
    "./types": "./src/types.ts",
    "./adapters": "./src/adapters/index.ts"
  },
  "scripts": {
    "build": "echo 'No build - using tsx for dynamic TypeScript execution'",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "echo 'Use tsx for runtime - TypeScript module resolution works at runtime'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@isc/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.1.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "tsx": "^4.7.0"
  },
  "keywords": [
    "isc",
    "social",
    "p2p",
    "posts",
    "feeds",
    "chat"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
