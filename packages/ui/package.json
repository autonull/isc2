{
  "name": "@isc/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./providers": "./src/providers/index.ts",
    "./styles": "./src/styles/index.ts",
    "./tokens": "./src/styles/tokens.ts"
  },
  "scripts": {
    "build": "echo 'No build - using tsx'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "echo 'Use tsx for runtime'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@isc/core": "workspace:*",
    "@isc/state": "workspace:*"
  },
  "peerDependencies": {
    "preact": "^10.x"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.1.0",
    "happy-dom": "^12.10.3",
    "preact": "^10.19.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "isc",
    "ui",
    "components",
    "preact"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
