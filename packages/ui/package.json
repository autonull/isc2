{
  "name": "@isc/ui",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./components": "./dist/components/index.js",
    "./hooks": "./dist/hooks/index.js",
    "./providers": "./dist/providers/index.js",
    "./styles": "./dist/styles/index.js",
    "./tokens": "./dist/styles/tokens.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@isc/core": "workspace:*",
    "@isc/state": "workspace:*"
  },
  "peerDependencies": {
    "preact": "^10.x"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.1.0",
    "happy-dom": "^12.10.3",
    "preact": "^10.19.3",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "isc",
    "ui",
    "components",
    "preact"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
