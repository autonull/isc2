{
  "name": "@isc/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./math": "./src/math/index.ts",
    "./semantic": "./src/semantic/index.ts",
    "./crypto": "./src/crypto/index.ts",
    "./types": "./src/types.ts",
    "./encoding": "./src/encoding.ts",
    "./stake": "./src/stake/index.ts",
    "./reputation": "./src/reputation/index.ts"
  },
  "scripts": {
    "build": "echo 'No build - using tsx for dynamic TypeScript execution'",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "echo 'Use tsx for runtime - TypeScript module resolution works at runtime'",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^12.10.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "isc",
    "p2p",
    "semantic",
    "embeddings"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
